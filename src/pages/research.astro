---
// Research — 상단 "Research Themes" thrust 5개 (호버 카드 + 모달) + 역연대기 highlight 타임라인
// 데이터: src/content/research-themes/*.md, src/content/research-highlights/*.md, src/content/publications/skku.json
// 이미지 등록 규칙: src/assets/research/README.md 참고
import BaseLayout from '@layouts/BaseLayout.astro';
import FigureSlot from '@components/FigureSlot.astro';
import ThemeIcon from '@components/ThemeIcon.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import type { ImageMetadata } from 'astro';
import { formatChemistry } from '@/utils/chemistry';
import { papersForTheme, type ThemeSlug } from '@/utils/themeClassifier';

type ResearchHighlight = CollectionEntry<'research-highlights'>['data'];

// src/assets/research/* 의 모든 figure 파일을 build-time에 eager-load
const figureModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/research/*.{jpg,jpeg,png,webp}',
  { eager: true }
);

const getFigure = (filename?: string): ImageMetadata | null => {
  if (!filename) return null;
  const mod = figureModules[`/src/assets/research/${filename}`];
  return mod?.default ?? null;
};

// ─── Highlights 데이터 로드 ───
const highlightEntries = await getCollection('research-highlights');
const highlights = highlightEntries
  .map((e) => e.data)
  .sort((a, b) => a.order - b.order);

// 연도별 그룹핑 (역연대기). 데이터가 reverse-chrono로 정렬되어 있어 그대로 받음.
const byYear = highlights.reduce<Record<number, ResearchHighlight[]>>(
  (acc, h) => {
    (acc[h.year] ??= []).push(h);
    return acc;
  },
  {}
);

const years = Object.keys(byYear)
  .map(Number)
  .sort((a, b) => b - a);

// ─── Themes + 슬러그→연도 lookup + relatedPapers 룩업 (publications-skku) ───
const themeEntries = await getCollection('research-themes');
const themes = themeEntries
  .map((e) => e.data)
  .sort((a, b) => a.order - b.order);

const slugToYear = new Map<string, number>(
  highlightEntries.map((e) => [e.id, e.data.year])
);

// 모달 paper list 데이터 — publications-skku의 lead-author 2016+ paper를 키워드로 자동 분류
// 새 paper가 CMS로 추가되면 다음 빌드에서 자동으로 해당 테마 모달에 등장.
// 키워드/override는 src/utils/themeClassifier.ts 에서 관리.
const allSkkuPapers = (await getCollection('publications-skku')).map((e) => e.data);
const leadPapers = allSkkuPapers.filter((p) => p.lead && p.year >= 2016);

const themeCards = themes.map((theme) => {
  const relatedYears = theme.relatedHighlights
    .map((slug) => slugToYear.get(slug))
    .filter((y): y is number => typeof y === 'number');
  const anchorYear = relatedYears.length ? Math.max(...relatedYears) : null;

  const papers = papersForTheme(theme.slug as ThemeSlug, leadPapers);

  return {
    ...theme,
    highlightCount: theme.relatedHighlights.length,
    anchorYear,
    papers,
    paperCount: papers.length,
  };
});

---

<BaseLayout
  title="Research · SKKU-STEM Lab"
  description="Selected research highlights from the SKKU-STEM Laboratory at Sungkyunkwan University, in reverse chronological order."
>
  <div class="section-stack pb-24 md:pb-32">
    {/* ─────────────── Page header ─────────────── */}
    <section class="container-page pt-12 md:pt-20 relative">
      {/* 배경 그래픽 — 에너지 지형(등고선) + 원자 위치. 우측 깊은 우물에 코랄 원자가 안착하는 구도. */}
      <svg
        viewBox="0 0 800 380"
        preserveAspectRatio="xMidYMid slice"
        class="absolute inset-0 w-full h-full pointer-events-none"
        aria-hidden="true"
      >
        <defs>
          <radialGradient id="research-atom-glow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#CC785C" stop-opacity="0.35" />
            <stop offset="60%" stop-color="#CC785C" stop-opacity="0.08" />
            <stop offset="100%" stop-color="#CC785C" stop-opacity="0" />
          </radialGradient>
        </defs>

        {/* 주 우물 — 우측 deep minimum (코랄 등고선) */}
        <g
          fill="none"
          class="stroke-coral"
          stroke-width="0.9"
          opacity="0.22"
        >
          <ellipse cx="610" cy="195" rx="240" ry="170" />
          <ellipse cx="610" cy="195" rx="195" ry="135" />
          <ellipse cx="610" cy="195" rx="150" ry="103" />
          <ellipse cx="610" cy="195" rx="108" ry="74" />
          <ellipse cx="610" cy="195" rx="70" ry="48" />
          <ellipse cx="610" cy="195" rx="36" ry="25" />
          <ellipse cx="610" cy="195" rx="14" ry="10" />
        </g>

        {/* 부 우물 — 좌측 saddle (잉크 등고선, 살짝 회전) */}
        <g
          fill="none"
          class="stroke-ink"
          stroke-width="0.7"
          opacity="0.10"
          transform="rotate(-12 380 290)"
        >
          <ellipse cx="380" cy="290" rx="115" ry="60" />
          <ellipse cx="380" cy="290" rx="78" ry="40" />
          <ellipse cx="380" cy="290" rx="42" ry="22" />
        </g>

        {/* Shuttle trajectory — 좌상단에서 우측 우물 중심으로 가는 dashed path */}
        <path
          d="M 60 70 Q 280 130 420 180 T 605 192"
          fill="none"
          class="stroke-coral"
          stroke-width="0.9"
          stroke-dasharray="2 5"
          opacity="0.35"
        />

        {/* 분산된 원자 위치 */}
        <g class="fill-ink" opacity="0.38">
          <circle cx="120" cy="130" r="1.6" />
          <circle cx="200" cy="220" r="1.6" />
          <circle cx="305" cy="105" r="1.6" />
          <circle cx="380" cy="290" r="2" />
          <circle cx="455" cy="335" r="1.6" />
          <circle cx="500" cy="65" r="1.6" />
          <circle cx="545" cy="265" r="1.6" />
          <circle cx="685" cy="95" r="1.6" />
          <circle cx="745" cy="240" r="1.6" />
          <circle cx="715" cy="320" r="1.6" />
          <circle cx="80" cy="300" r="1.6" />
        </g>

        {/* 깊은 우물 중앙의 featured atom — coral glow + dot */}
        <circle cx="610" cy="195" r="32" fill="url(#research-atom-glow)" />
        <circle cx="610" cy="195" r="4.5" fill="#CC785C" />
      </svg>

      <div class="relative max-w-2xl">
        <p class="font-mono text-xs uppercase tracking-[0.16em] text-coral-700">
          Research
        </p>
        <h1
          class="mt-6 font-display font-normal tracking-tight text-5xl md:text-6xl leading-[1.05]"
        >
          Resolving matter
        </h1>
        <p class="mt-8 text-lg md:text-xl text-ink/80 leading-relaxed">
          Research from the SKKU-STEM Lab &mdash; methods at the intersection
          of scanning transmission electron microscopy, electron spectroscopy,
          and machine learning, applied to energy materials.
        </p>
        <p
          class="mt-7 font-display italic text-xl md:text-2xl text-coral/85 leading-snug"
        >
          &ldquo;A shuttle guiding us to atomic world.&rdquo;
        </p>
      </div>
    </section>

    {/* ─────────────── Research Themes — 2열 카드 그리드 + 모달 ─────────────── */}
    <section class="container-page">
      <header class="max-w-3xl">
        <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-coral-700">
          Research Themes
        </p>
        <h2
          class="mt-3 font-display font-normal text-3xl md:text-4xl tracking-tight leading-tight"
        >
          Six thrusts at the intersection of microscopy, spectroscopy, and ML.
        </h2>
      </header>

      <div class="mt-10 md:mt-14 grid md:grid-cols-2 gap-5 md:gap-6">
        {
          themeCards.map((card) => (
            <article class="theme-card relative rounded-lg border border-cream-300 bg-cream-200/70 hover:bg-cream-200 hover:border-coral/40 hover:shadow-lift transition-all duration-300 p-6 md:p-8 flex flex-col">
              <ThemeIcon
                slug={card.slug}
                class="absolute top-5 right-5 w-7 h-7 text-coral/70"
              />

              <div class="flex-1 flex flex-col pr-10">
                <button
                  type="button"
                  data-theme-modal-open={card.slug}
                  class="text-left w-full transition-colors hover:text-coral focus-visible:text-coral outline-none"
                >
                  <h3
                    class="font-display font-normal text-xl md:text-2xl tracking-tight leading-snug text-balance"
                    set:html={formatChemistry(card.title)}
                  />
                </button>
                <p
                  class="mt-2 font-mono text-[11px] uppercase tracking-[0.14em] text-coral-700 font-bold"
                  set:html={formatChemistry(card.subtitle)}
                />
                <p
                  class="mt-4 font-serif text-base leading-relaxed text-ink/85 flex-1"
                  set:html={formatChemistry(card.summary)}
                />

                {card.paperCount > 0 && (
                  <div class="mt-6">
                    <button
                      type="button"
                      data-theme-modal-open={card.slug}
                      class="inline-flex items-center gap-2 px-4 py-2 bg-ink text-cream rounded-md text-[11px] font-mono uppercase tracking-[0.14em] hover:bg-ink-700 transition-colors animate-breathe"
                    >
                      Related papers
                      <span class="tabular-nums opacity-90">
                        ({card.paperCount})
                      </span>
                    </button>
                  </div>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </section>

    {/* ─────────────── Theme modals (paper list per theme) ─────────────── */}
    {
      themeCards.map((card) => (
        <dialog
          id={`theme-modal-${card.slug}`}
          class="theme-modal bg-cream text-ink rounded-lg shadow-lift w-full max-w-3xl p-0"
          aria-label={`${card.title} — related papers`}
        >
          <div class="theme-modal-inner flex flex-col">
            <header class="sticky top-0 bg-cream/95 backdrop-blur-sm border-b border-ink/15 px-5 md:px-7 py-4 flex items-start justify-between gap-4 z-10">
              <div class="min-w-0">
                <p class="font-mono text-[10px] uppercase tracking-[0.16em] text-coral-700">
                  Theme {card.order} · {card.paperCount} lead-author papers
                </p>
                <h2
                  class="mt-1 font-display font-normal text-lg md:text-xl tracking-tight leading-snug text-balance"
                  set:html={formatChemistry(card.title)}
                />
              </div>
              <button
                type="button"
                data-theme-modal-close
                class="shrink-0 inline-flex items-center justify-center h-9 w-9 rounded-md text-ink/70 hover:text-coral hover:bg-cream-200 transition-colors"
                aria-label="Close"
              >
                <svg
                  class="h-5 w-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  aria-hidden="true"
                >
                  <path d="M6 6l12 12M18 6 6 18" />
                </svg>
              </button>
            </header>

            <ol class="px-5 md:px-7 py-3 divide-y divide-ink/10">
              {card.papers.map((p) => (
                <li class="py-3 grid grid-cols-[2.5rem_1fr] gap-x-4">
                  <span class="font-mono text-sm tabular-nums text-right pt-0.5 text-coral-700 font-medium">
                    {p.number}
                  </span>
                  <div class="min-w-0">
                    <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-coral-700 font-bold">
                      {p.journal}
                      {p.volumePages && (
                        <span class="text-ink/65 normal-case font-normal ml-1.5">
                          &middot; {p.volumePages}
                        </span>
                      )}
                      <span class="text-ink/65 normal-case font-normal ml-1.5">
                        &middot; {p.year}
                      </span>
                    </p>
                    <p class="mt-1.5 text-sm md:text-base leading-snug font-serif text-ink/95">
                      {p.doi ? (
                        <a
                          href={p.doi}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="hover:text-coral transition-colors"
                          set:html={formatChemistry(p.title)}
                        />
                      ) : (
                        <Fragment set:html={formatChemistry(p.title)} />
                      )}
                    </p>
                    <p class="mt-1.5 text-xs text-ink/60 leading-relaxed">
                      {p.authors}
                    </p>
                  </div>
                </li>
              ))}
            </ol>
          </div>
        </dialog>
      ))
    }

    {/* ─────────────── Year jump nav ─────────────── */}
    <section id="highlights" class="container-page scroll-mt-20">
      <header class="max-w-3xl mb-8 md:mb-10">
        <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-coral-700">
          Research Highlights
        </p>
        <h2
          class="mt-3 font-display font-normal text-3xl md:text-4xl tracking-tight leading-tight"
        >
          Selected publications, year by year.
        </h2>
      </header>

      <nav
        aria-label="Jump to year"
        class="flex flex-wrap items-baseline gap-x-3 gap-y-2 pb-6 border-b border-ink/15"
      >
        <span
          class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink/70 mr-2"
        >
          Jump
        </span>
        {
          years.map((year) => (
            <a
              href={`#year-${year}`}
              class="font-mono text-sm tabular-nums text-ink/70 hover:text-coral transition-colors"
            >
              {year}
            </a>
          ))
        }
      </nav>
    </section>

    {/* ─────────────── Highlights timeline ─────────────── */}
    <section class="container-page">
      <div class="space-y-12 md:space-y-16">
        {
          years.map((year) => (
            <div class="grid md:grid-cols-[5rem_1fr] gap-x-8 lg:gap-x-12">
              <h2
                id={`year-${year}`}
                class="md:sticky md:top-20 self-start scroll-mt-20 font-display font-normal text-3xl md:text-4xl tracking-tight tabular-nums text-coral"
              >
                {year}
              </h2>

              <ul class="space-y-12 md:space-y-16">
                {byYear[year].map((entry) => (
                  <li>
                    <div class="grid lg:grid-cols-[1fr_auto] gap-5 lg:gap-8 items-start">
                      <div class="min-w-0">
                        <h3 class="font-display font-normal text-xl md:text-2xl tracking-tight leading-snug text-balance">
                          {entry.doi ? (
                            <a
                              href={entry.doi}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="hover:text-coral transition-colors"
                              set:html={formatChemistry(entry.title)}
                            />
                          ) : (
                            <Fragment set:html={formatChemistry(entry.title)} />
                          )}
                        </h3>
                        <p
                          class="mt-3 font-serif text-base md:text-lg leading-relaxed text-ink/85"
                          set:html={formatChemistry(entry.summary)}
                        />


                        <p class="mt-4 font-mono text-[11px] uppercase tracking-[0.14em] text-coral-700 font-bold">
                          {entry.journal}
                          <span class="text-ink/65 normal-case font-normal ml-1.5">
                            &middot; {entry.volumePages}
                          </span>
                        </p>

                        {(entry.codeUrl || entry.mention) && (
                          <div class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-2 text-[11px] uppercase tracking-[0.14em]">
                            {entry.codeUrl && (
                              <a
                                href={entry.codeUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-ink/65 hover:text-coral transition-colors inline-flex items-center gap-1"
                              >
                                Code <span aria-hidden="true">&rarr;</span>
                              </a>
                            )}

                            {entry.mention &&
                              (entry.mentionUrl ? (
                                <a
                                  href={entry.mentionUrl}
                                  target="_blank"
                                  rel="noopener noreferrer"
                                  class="normal-case tracking-normal text-xs italic text-coral-700 hover:text-coral-700 transition-colors inline-flex items-center gap-1.5"
                                >
                                  <span aria-hidden="true">&#9733;</span>
                                  {entry.mention}
                                </a>
                              ) : (
                                <span class="normal-case tracking-normal text-xs italic text-coral-700 inline-flex items-center gap-1.5">
                                  <span aria-hidden="true">&#9733;</span>
                                  {entry.mention}
                                </span>
                              ))}
                          </div>
                        )}
                      </div>

                      <FigureSlot
                        image={getFigure(entry.image)}
                        alt={entry.imageAlt ?? entry.title}
                        class="w-full lg:w-72 xl:w-80 shrink-0"
                        aspectClass="aspect-[4/3]"
                      />
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* Modal — 모바일에서는 화면 거의 가득, 데스크톱은 6vh top + 80vh max */
  .theme-modal {
    border: 1px solid #e4e1d5;
    margin: 6vh auto auto;
    max-height: 85dvh;
    overflow: hidden;
  }

  .theme-modal-inner {
    max-height: 85dvh;
    overflow-y: auto;
  }

  .theme-modal::backdrop {
    background: rgba(20, 20, 19, 0.42);
    backdrop-filter: blur(2px);
  }

  @media (max-width: 640px) {
    .theme-modal {
      margin: 0;
      max-width: 100vw;
      width: 100vw;
      max-height: 100dvh;
      height: 100dvh;
      border-radius: 0;
      border: 0;
    }
    .theme-modal-inner {
      max-height: 100dvh;
    }
  }
</style>

<script>
  // Theme 카드 클릭 → 해당 모달 열기, 백드롭/X 버튼/ESC 으로 닫기
  const openButtons = document.querySelectorAll<HTMLButtonElement>(
    '[data-theme-modal-open]',
  );

  openButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const slug = btn.getAttribute('data-theme-modal-open');
      if (!slug) return;
      const dialog = document.getElementById(
        `theme-modal-${slug}`,
      ) as HTMLDialogElement | null;
      if (dialog && !dialog.open) dialog.showModal();
    });
  });

  document.querySelectorAll<HTMLDialogElement>('dialog.theme-modal').forEach(
    (dialog) => {
      // X 버튼
      dialog
        .querySelectorAll<HTMLButtonElement>('[data-theme-modal-close]')
        .forEach((b) => b.addEventListener('click', () => dialog.close()));

      // 백드롭 클릭
      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) dialog.close();
      });
    },
  );
</script>
