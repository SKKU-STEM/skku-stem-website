---
// Research — 역연대기 highlight 타임라인 (text + 대표 figure 2열)
// 데이터 출처: src/data/research-highlights.ts (이전 사이트 /clients 마이그레이션)
// 이미지 등록 규칙: src/assets/research/README.md 참고
import BaseLayout from '@layouts/BaseLayout.astro';
import FigureSlot from '@components/FigureSlot.astro';
import { highlights } from '@/data/research-highlights';
import type { ResearchHighlight } from '@/data/research-highlights';
import type { ImageMetadata } from 'astro';
import { formatChemistry } from '@/utils/chemistry';

// src/assets/research/* 의 모든 figure 파일을 build-time에 eager-load
const figureModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/research/*.{jpg,jpeg,png,webp}',
  { eager: true }
);

const getFigure = (filename?: string): ImageMetadata | null => {
  if (!filename) return null;
  const mod = figureModules[`/src/assets/research/${filename}`];
  return mod?.default ?? null;
};

// 연도별 그룹핑 (역연대기). 데이터가 reverse-chrono로 정렬되어 있어 그대로 받음.
const byYear = highlights.reduce<Record<number, ResearchHighlight[]>>(
  (acc, h) => {
    (acc[h.year] ??= []).push(h);
    return acc;
  },
  {}
);

const years = Object.keys(byYear)
  .map(Number)
  .sort((a, b) => b - a);

// 헤더 우측 GIF 슬롯 — public/research/<filename> 안의 파일을 가리킴.
// GIF 준비되면 아래 null을 경로 문자열로 교체. 비워두면 점선 placeholder("GIF") 표시.
// 예시: const headerGif = '/research/intro.gif';
const headerGif = null as string | null;
const headerGifAlt = 'Research header animation';
---

<BaseLayout
  title="Research · SKKU-STEM Lab"
  description="Selected research highlights from the SKKU-STEM Laboratory at Sungkyunkwan University, in reverse chronological order."
>
  <div class="section-stack pb-24 md:pb-32">
    {/* ─────────────── Page header ─────────────── */}
    <section class="container-page pt-12 md:pt-20">
      <div class="grid md:grid-cols-[1fr_auto] gap-10 lg:gap-14 items-start">
        <div class="max-w-2xl">
          <p class="font-mono text-xs uppercase tracking-[0.16em] text-coral">
            Research
          </p>
          <h1
            class="mt-6 font-display font-normal tracking-tight text-5xl md:text-6xl leading-[1.05]"
          >
            Selected work
          </h1>
          <p class="mt-8 text-lg md:text-xl text-ink/80 leading-relaxed">
            Research from the SKKU-STEM Lab &mdash; methods at the intersection
            of scanning transmission electron microscopy, electron spectroscopy,
            and machine learning, applied to energy materials.
          </p>
          <p
            class="mt-7 font-display italic text-xl md:text-2xl text-coral/85 leading-snug"
          >
            &ldquo;A shuttle guiding us to atomic world.&rdquo;
          </p>
        </div>

        {/* GIF 슬롯 — 우측 상단. 자세한 등록 방법은 frontmatter의 headerGif 주석 참고. */}
        <div class="w-full md:w-64 lg:w-80 shrink-0">
          {
            headerGif ? (
              <img
                src={headerGif}
                alt={headerGifAlt}
                class="aspect-square object-cover w-full"
              />
            ) : (
              <div
                class="aspect-square bg-cream-200/60 border border-dashed border-ink/15 flex items-center justify-center"
                role="img"
                aria-label="Header GIF placeholder"
              >
                <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-ink/40 select-none">
                  GIF
                </span>
              </div>
            )
          }
        </div>
      </div>
    </section>

    {/* ─────────────── Year jump nav ─────────────── */}
    <section class="container-page">
      <nav
        aria-label="Jump to year"
        class="flex flex-wrap items-baseline gap-x-3 gap-y-2 pb-6 border-b border-ink/15"
      >
        <span
          class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink/55 mr-2"
        >
          Jump
        </span>
        {
          years.map((year) => (
            <a
              href={`#year-${year}`}
              class="font-mono text-sm tabular-nums text-ink/70 hover:text-coral transition-colors"
            >
              {year}
            </a>
          ))
        }
      </nav>
    </section>

    {/* ─────────────── Highlights timeline ─────────────── */}
    <section class="container-page">
      <div class="space-y-12 md:space-y-16">
        {
          years.map((year) => (
            <div class="grid md:grid-cols-[5rem_1fr] gap-x-8 lg:gap-x-12">
              <h2
                id={`year-${year}`}
                class="md:sticky md:top-20 self-start scroll-mt-20 font-display font-normal text-3xl md:text-4xl tracking-tight tabular-nums text-coral"
              >
                {year}
              </h2>

              <ul class="space-y-12 md:space-y-16">
                {byYear[year].map((entry) => (
                  <li>
                    <div class="grid lg:grid-cols-[1fr_auto] gap-5 lg:gap-8 items-start">
                      <div class="min-w-0">
                        <h3 class="font-display font-normal text-xl md:text-2xl tracking-tight leading-snug text-balance">
                          {entry.doi ? (
                            <a
                              href={entry.doi}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="hover:text-coral transition-colors"
                              set:html={formatChemistry(entry.title)}
                            />
                          ) : (
                            <Fragment set:html={formatChemistry(entry.title)} />
                          )}
                        </h3>
                        <p
                          class="mt-3 font-serif text-base md:text-lg leading-relaxed text-ink/85"
                          set:html={formatChemistry(entry.summary)}
                        />


                        <p class="mt-4 font-mono text-[11px] uppercase tracking-[0.14em] text-coral font-bold">
                          {entry.journal}
                          <span class="text-ink/50 normal-case font-normal ml-1.5">
                            &middot; {entry.volumePages}
                          </span>
                        </p>

                        {(entry.codeUrl || entry.mention) && (
                          <div class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-2 text-[11px] uppercase tracking-[0.14em]">
                            {entry.codeUrl && (
                              <a
                                href={entry.codeUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-ink/65 hover:text-coral transition-colors inline-flex items-center gap-1"
                              >
                                Code <span aria-hidden="true">&rarr;</span>
                              </a>
                            )}

                            {entry.mention &&
                              (entry.mentionUrl ? (
                                <a
                                  href={entry.mentionUrl}
                                  target="_blank"
                                  rel="noopener noreferrer"
                                  class="normal-case tracking-normal text-xs italic text-coral hover:text-coral-700 transition-colors inline-flex items-center gap-1.5"
                                >
                                  <span aria-hidden="true">&#9733;</span>
                                  {entry.mention}
                                </a>
                              ) : (
                                <span class="normal-case tracking-normal text-xs italic text-coral inline-flex items-center gap-1.5">
                                  <span aria-hidden="true">&#9733;</span>
                                  {entry.mention}
                                </span>
                              ))}
                          </div>
                        )}
                      </div>

                      <FigureSlot
                        image={getFigure(entry.image)}
                        alt={entry.imageAlt ?? entry.title}
                        class="w-full lg:w-72 xl:w-80 shrink-0"
                        aspectClass="aspect-[4/3]"
                      />
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
