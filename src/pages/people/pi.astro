          </dt>
          <dd class="text-ink/85 leading-relaxed">
            Department of Energy Science<br />
            Sungkyunkwan University<br />
            2066 Seobu-ro, Jangan-gu<br />
            Suwon 16419, Republic of Korea
          </dd>
        </dl>
      </div>
    </section>
  </div>
</BaseLayout>
