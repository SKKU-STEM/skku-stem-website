                      class="font-mono text-sm text-ink/55 tabular-nums whitespace-nowrap"
                      datetime={String(pub.year)}
                    >
                      {pub.year}
                    </time>
                    <div>
                      <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-coral">
                        {pub.journal}
                        {pub.volumePages && (
                          <span class="text-ink/50 normal-case ml-1.5">
                            &middot; {pub.volumePages}
                          </span>
                        )}
                      </p>
                      <p class="mt-1.5 text-base md:text-lg leading-snug font-serif text-ink/95">
                        {pub.doi ? (
                          <a
                            href={pub.doi}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="hover:text-coral transition-colors"
                            set:html={formatChemistry(pub.title)}
                          />
                        ) : (
                          <Fragment set:html={formatChemistry(pub.title)} />
                        )}
                      </p>
                      <p class="mt-2 text-xs text-ink/65 leading-relaxed">
                        {pub.authors}
                      </p>
                      {pub.doi && (
                        <a
                          href={pub.doi}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="mt-2 inline-flex items-center gap-1 text-[10px] uppercase tracking-[0.14em] text-ink/55 hover:text-coral transition-colors"
                        >
                          DOI <span aria-hidden="true">&rarr;</span>
                        </a>
                      )}
                    </div>
                  </li>
                ))}
              </ol>
            </div>
          ))
        }

        <p class="mt-10 pt-6 border-t border-ink/15 text-xs text-ink/55 italic leading-relaxed">
          &dagger; equal contribution &middot; * indicates corresponding author(s)
        </p>
      </div>
    </section>

    {/* ─────────────── Contact ─────────────── */}
    <section id="contact" class="container-page scroll-mt-12 md:scroll-mt-20">
