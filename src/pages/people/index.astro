---
// People — 이전 SKKU-STEM 사이트의 Members 페이지 마이그레이션
// 출처: https://sites.google.com/site/skkustem/our-company (2026-05-09 fetch)
// PI 상세 CV는 /people/pi에 분리. 본 페이지는 멤버 카드 그리드 + alumni.
//
// Portrait: 카드 우측 상단 슬롯 (3:4). 사진은 public/members/<INIT>.jpg에 두고
// frontmatter의 photoPath 필드로 참조 (예: /members/EBP.jpg).
// 멤버 데이터는 src/content/members/*.md 컬렉션에 저장 (section 필드로 그룹).
import BaseLayout from '@layouts/BaseLayout.astro';
import PortraitBox from '@components/PortraitBox.astro';
import { getCollection } from 'astro:content';

const allMembers = (await getCollection('members'))
  .map((e) => e.data)
  .sort((a, b) => a.order - b.order);

const postdocs = allMembers.filter((m) => m.section === 'postdoc');
const phdCandidates = allMembers.filter((m) => m.section === 'phd');
const undergrads = allMembers.filter((m) => m.section === 'undergrad');
const alumni = allMembers.filter((m) => m.section === 'alumni');

const obfuscate = (email: string): string => email.replace('@', '[at]');
---

<BaseLayout
  title="People · SKKU-STEM Lab"
  description="Members of the SKKU-STEM Laboratory at Sungkyunkwan University — postdoctoral researchers, graduate and undergraduate students, and alumni."
>
  <div class="section-stack pb-24 md:pb-32">
    {/* ─────────────── Page header ─────────────── */}
    <section class="container-page pt-12 md:pt-20 relative">
      {/* 배경 그래픽 — 5-layer × 4-node feedforward network. 헤더 전폭에 펼쳐 은은하게 장식.
          노드=멤버, 엣지=협업/데이터 흐름. 활성 경로(코랄 polyline)는 5개 featured 노드를 가로지른다. */}
      <svg
        viewBox="0 0 800 200"
        preserveAspectRatio="xMidYMid slice"
        class="absolute inset-0 w-full h-full pointer-events-none"
        aria-hidden="true"
      >
        <defs>
          <radialGradient id="people-node-glow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#CC785C" stop-opacity="0.30" />
            <stop offset="60%" stop-color="#CC785C" stop-opacity="0.06" />
            <stop offset="100%" stop-color="#CC785C" stop-opacity="0" />
          </radialGradient>
        </defs>

        {/* Regular edges — 4쌍 layer 사이 fully-connected (활성 경로 4 edge 제외, 총 60개) */}
        <path
          fill="none"
          class="stroke-ink"
          stroke-width="0.5"
          opacity="0.10"
          d="M 60 35 L 235 35 M 60 35 L 235 80 M 60 35 L 235 125 M 60 35 L 235 170 M 60 80 L 235 35 M 60 80 L 235 80 M 60 80 L 235 170 M 60 125 L 235 35 M 60 125 L 235 80 M 60 125 L 235 125 M 60 125 L 235 170 M 60 170 L 235 35 M 60 170 L 235 80 M 60 170 L 235 125 M 60 170 L 235 170 M 235 35 L 410 35 M 235 35 L 410 80 M 235 35 L 410 125 M 235 35 L 410 170 M 235 80 L 410 35 M 235 80 L 410 80 M 235 80 L 410 125 M 235 80 L 410 170 M 235 125 L 410 80 M 235 125 L 410 125 M 235 125 L 410 170 M 235 170 L 410 35 M 235 170 L 410 80 M 235 170 L 410 125 M 235 170 L 410 170 M 410 35 L 585 35 M 410 35 L 585 80 M 410 35 L 585 125 M 410 80 L 585 35 M 410 80 L 585 80 M 410 80 L 585 125 M 410 80 L 585 170 M 410 125 L 585 35 M 410 125 L 585 80 M 410 125 L 585 125 M 410 125 L 585 170 M 410 170 L 585 35 M 410 170 L 585 80 M 410 170 L 585 125 M 410 170 L 585 170 M 585 35 L 760 35 M 585 35 L 760 80 M 585 35 L 760 125 M 585 35 L 760 170 M 585 80 L 760 35 M 585 80 L 760 80 M 585 80 L 760 125 M 585 80 L 760 170 M 585 125 L 760 35 M 585 125 L 760 80 M 585 125 L 760 125 M 585 125 L 760 170 M 585 170 L 760 35 M 585 170 L 760 125 M 585 170 L 760 170"
        />

        {/* Active path — 헤더 전체를 가로지르는 활성 신호 (5 featured 노드를 polyline으로 연결) */}
        <path
          fill="none"
          class="stroke-coral"
          stroke-width="0.95"
          opacity="0.42"
          d="M 60 80 L 235 125 L 410 35 L 585 170 L 760 80"
        />

        {/* Regular 노드 (15개) */}
        <g class="fill-ink" opacity="0.36">
          <circle cx="60" cy="35" r="2.2" />
          <circle cx="60" cy="125" r="2.2" />
          <circle cx="60" cy="170" r="2.2" />
          <circle cx="235" cy="35" r="2.2" />
          <circle cx="235" cy="80" r="2.2" />
          <circle cx="235" cy="170" r="2.2" />
          <circle cx="410" cy="80" r="2.2" />
          <circle cx="410" cy="125" r="2.2" />
          <circle cx="410" cy="170" r="2.2" />
          <circle cx="585" cy="35" r="2.2" />
          <circle cx="585" cy="80" r="2.2" />
          <circle cx="585" cy="125" r="2.2" />
          <circle cx="760" cy="35" r="2.2" />
          <circle cx="760" cy="125" r="2.2" />
          <circle cx="760" cy="170" r="2.2" />
        </g>

        {/* Featured 노드 (5개, layer 당 1개) — coral glow + dot */}
        <circle cx="60" cy="80" r="13" fill="url(#people-node-glow)" />
        <circle cx="60" cy="80" r="3.3" fill="#CC785C" />
        <circle cx="235" cy="125" r="13" fill="url(#people-node-glow)" />
        <circle cx="235" cy="125" r="3.3" fill="#CC785C" />
        <circle cx="410" cy="35" r="13" fill="url(#people-node-glow)" />
        <circle cx="410" cy="35" r="3.3" fill="#CC785C" />
        <circle cx="585" cy="170" r="13" fill="url(#people-node-glow)" />
        <circle cx="585" cy="170" r="3.3" fill="#CC785C" />
        <circle cx="760" cy="80" r="13" fill="url(#people-node-glow)" />
        <circle cx="760" cy="80" r="3.3" fill="#CC785C" />
      </svg>

      <div class="relative">
        <p class="font-mono text-xs uppercase tracking-[0.16em] text-coral-700">
          People
        </p>
        <h1
          class="mt-6 font-display font-normal tracking-tight text-5xl md:text-6xl leading-[1.05]"
        >
          The SKKU-STEM lab
        </h1>
      </div>
    </section>

    {/* ─────────────── PI feature card ─────────────── */}
    <section class="container-page">
      <div
        class="grid md:grid-cols-[200px_1fr] lg:grid-cols-[240px_1fr] gap-8 md:gap-12 items-start border border-ink/15 p-6 md:p-10 transition-all duration-200 hover:-translate-y-0.5 hover:border-ink/40 hover:shadow-soft"
      >
        <img
          src="/members/YMK.jpg"
          alt="Prof. Young-Min Kim"
          class="aspect-[3/4] object-cover w-full max-w-[240px]"
          width="240"
          height="320"
          loading="eager"
          fetchpriority="high"
        />

        <div>
          <p
            class="font-mono text-xs uppercase tracking-[0.16em] text-coral-700"
          >
            Principal Investigator
          </p>
          <h2
            class="mt-4 font-display font-normal tracking-tight text-3xl md:text-4xl leading-tight"
          >
            김영민
            <span class="block md:inline mt-1 md:mt-0 md:ml-2 text-2xl md:text-3xl text-ink/60 italic">
              Young-Min Kim
            </span>
          </h2>
          <p class="mt-3 text-base text-ink/70 leading-relaxed">
            Professor, Department of Energy Science<br />
            Sungkyunkwan University
          </p>

          <p
            class="mt-6 text-base md:text-lg text-ink/85 leading-relaxed font-serif"
          >
            Leads the SKKU-STEM Laboratory. Research integrates aberration-corrected
            scanning transmission electron microscopy and electron spectroscopy
            with machine learning, applied to atomic-scale problems in energy
            materials. Joined SKKU as Assistant Professor in 2016, after a
            postdoctoral fellowship at Oak Ridge National Laboratory and a
            Principal Researcher position at the Korea Basic Science Institute.
          </p>

          <div
            class="mt-7 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm"
          >
            <a
              href="mailto:youngmk@skku.edu"
              class="text-ink hover:text-coral transition-colors"
            >
              youngmk[at]skku.edu
            </a>
            <span aria-hidden="true" class="text-ink/55">·</span>
            <a
              href="tel:+82312994059"
              class="text-ink/80 hover:text-coral transition-colors"
            >
              +82-(0)31-299-4059
            </a>
            <span aria-hidden="true" class="text-ink/55">·</span>
            <a
              href="https://orcid.org/0000-0003-3220-9004"
              target="_blank"
              rel="noopener noreferrer"
              class="text-ink/80 hover:text-coral transition-colors"
            >
              ORCID
            </a>
            <a
              href="/people/pi"
              class="inline-flex items-center px-4 py-1.5 bg-ink text-cream text-sm font-medium rounded-md hover:bg-ink-700 transition-colors animate-breathe"
            >
              Full CV
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* ─────────────── Postdoctoral Researchers ─────────────── */}
    <section class="container-page">
      <h2
        class="font-mono text-2xl uppercase tracking-[0.16em] font-bold text-coral pb-4 border-b border-ink/15"
      >
        Postdoctoral Researchers
        <span class="ml-2 text-ink/65 tabular-nums">{postdocs.length}</span>
      </h2>

      <ul class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          postdocs.map((m) => (
            <li class="border border-ink/15 p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-ink/40 hover:shadow-soft">
              <div class="grid grid-cols-[1fr_auto] gap-4 sm:gap-5 items-start">
                <div class="min-w-0">
                  <p class="font-display text-lg font-normal leading-tight">
                    {m.nameKo}
                  </p>
                  <p class="mt-1 text-sm text-ink/65 italic">{m.nameEn}</p>

                  <p class="mt-5 font-mono text-[11px] uppercase tracking-[0.14em] text-coral-700">
                    {m.position}
                  </p>
                  <p class="mt-1 text-xs text-ink/65">
                    {m.program} · {m.yearRange}
                  </p>
                </div>
                <PortraitBox
                  srcPath={m.photoPath}
                  alt={`Portrait of ${m.nameEn}`}
                  class="w-24 shrink-0"
                />
              </div>

              <div class="mt-5 space-y-1.5 text-xs text-ink/70">
                <p>
                  <a
                    href={`mailto:${m.email}`}
                    class="hover:text-coral transition-colors break-all"
                  >
                    {obfuscate(m.email ?? '')}
                  </a>
                </p>
                <p>
                  <a
                    href={`https://orcid.org/${m.orcid}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-coral transition-colors"
                  >
                    ORCID {m.orcid}
                  </a>
                </p>
                {m.kri && (
                  <p class="text-ink/65 font-mono text-[10px]">KRI {m.kri}</p>
                )}
              </div>
            </li>
          ))
        }
      </ul>
    </section>

    {/* ─────────────── Ph.D. Candidates ─────────────── */}
    <section class="container-page">
      <h2
        class="font-mono text-2xl uppercase tracking-[0.16em] font-bold text-coral pb-4 border-b border-ink/15"
      >
        Ph.D. Candidates
        <span class="ml-2 text-ink/65 tabular-nums">{phdCandidates.length}</span>
      </h2>

      <ul class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          phdCandidates.map((m) => (
            <li class="border border-ink/15 p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-ink/40 hover:shadow-soft">
              <div class="grid grid-cols-[1fr_auto] gap-4 sm:gap-5 items-start">
                <div class="min-w-0">
                  <p class="font-display text-lg font-normal leading-tight">
                    {m.nameKo}
                  </p>
                  <p class="mt-1 text-sm text-ink/65 italic">{m.nameEn}</p>

                  <p class="mt-5 font-mono text-[11px] uppercase tracking-[0.14em] text-coral-700">
                    {m.program}
                  </p>
                  <p class="mt-1 text-xs text-ink/65 tabular-nums">
                    {m.yearRange}
                  </p>
                  {m.coAdvisor && (
                    <p class="mt-1 text-xs text-ink/70 italic">
                      Co-advisor: {m.coAdvisor}
                    </p>
                  )}
                </div>
                <PortraitBox
                  srcPath={m.photoPath}
                  alt={`Portrait of ${m.nameEn}`}
                  class="w-24 shrink-0"
                />
              </div>

              <div class="mt-5 space-y-1.5 text-xs text-ink/70">
                <p>
                  <a
                    href={`mailto:${m.email}`}
                    class="hover:text-coral transition-colors break-all"
                  >
                    {obfuscate(m.email ?? '')}
                  </a>
                </p>
                <p>
                  <a
                    href={`https://orcid.org/${m.orcid}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-coral transition-colors"
                  >
                    ORCID {m.orcid}
                  </a>
                </p>
                {m.kri && (
                  <p class="text-ink/65 font-mono text-[10px]">KRI {m.kri}</p>
                )}
              </div>
            </li>
          ))
        }
      </ul>
    </section>

    {/* ─────────────── Undergraduate Students ─────────────── */}
    <section class="container-page">
      <h2
        class="font-mono text-2xl uppercase tracking-[0.16em] font-bold text-coral pb-4 border-b border-ink/15"
      >
        Undergraduate Students
        <span class="ml-2 text-ink/65 tabular-nums">{undergrads.length}</span>
      </h2>

      <ul class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          undergrads.map((m) => (
            <li class="border border-ink/15 p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-ink/40 hover:shadow-soft">
              <div class="grid grid-cols-[1fr_auto] gap-4 sm:gap-5 items-start">
                <div class="min-w-0">
                  <p class="font-display text-lg font-normal leading-tight">
                    {m.nameKo}
                  </p>
                  <p class="mt-1 text-sm text-ink/65 italic">{m.nameEn}</p>

                  <p class="mt-5 font-mono text-[11px] uppercase tracking-[0.14em] text-coral-700">
                    {m.program}
                  </p>
                  <p class="mt-1 text-xs text-ink/65 tabular-nums">
                    {m.yearRange}
                  </p>
                </div>
                <PortraitBox
                  srcPath={m.photoPath}
                  alt={`Portrait of ${m.nameEn}`}
                  class="w-24 shrink-0"
                />
              </div>

              <div class="mt-5 space-y-1.5 text-xs text-ink/70">
                <p>
                  <a
                    href={`mailto:${m.email}`}
                    class="hover:text-coral transition-colors break-all"
                  >
                    {obfuscate(m.email ?? '')}
                  </a>
                </p>
                <p>
                  <a
                    href={`https://orcid.org/${m.orcid}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-coral transition-colors"
                  >
                    ORCID {m.orcid}
                  </a>
                </p>
                {m.kri && (
                  <p class="text-ink/65 font-mono text-[10px]">KRI {m.kri}</p>
                )}
              </div>
            </li>
          ))
        }
      </ul>
    </section>

    {/* ─────────────── Alumni ─────────────── */}
    <section class="container-page">
      <h2
        class="font-mono text-2xl uppercase tracking-[0.16em] font-bold text-coral pb-4 border-b border-ink/15"
      >
        Alumni
        <span class="ml-2 text-ink/65 tabular-nums">{alumni.length}</span>
      </h2>

      <ul class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          alumni.map((a) => (
            <li class="border border-ink/15 p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-ink/40 hover:shadow-soft">
              <div class="grid grid-cols-[1fr_auto] gap-4 items-start">
                <div class="min-w-0">
                  <p class="font-display text-base font-normal leading-tight">
                    {a.nameKo}
                  </p>
                  <p class="mt-1 text-sm text-ink/65 italic">{a.nameEn}</p>

                  <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.14em] text-ink/70">
                    {a.role}
                  </p>
                  {a.currentAffiliation && (
                    <p class="mt-1.5 text-xs text-ink/80 leading-relaxed">
                      <span aria-hidden="true" class="text-coral">
                        &rarr;
                      </span>{' '}
                      {a.currentAffiliation}
                    </p>
                  )}
                </div>
                <PortraitBox
                  srcPath={a.photoPath}
                  alt={`Portrait of ${a.nameEn}`}
                  class="w-24 shrink-0"
                />
              </div>

              {(a.email || a.orcid) && (
                <div class="mt-4 pt-4 border-t border-ink/10 space-y-1 text-[11px] text-ink/70">
                  {a.email && (
                    <p>
                      <a
                        href={`mailto:${a.email}`}
                        class="hover:text-coral transition-colors break-all"
                      >
                        {obfuscate(a.email)}
                      </a>
                    </p>
                  )}
                  {a.orcid && (
                    <p>
                      <a
                        href={`https://orcid.org/${a.orcid}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-coral transition-colors"
                      >
                        ORCID {a.orcid}
                      </a>
                    </p>
                  )}
                </div>
              )}
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>
