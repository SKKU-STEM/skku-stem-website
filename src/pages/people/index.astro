                        {obfuscate(a.email)}
                      </a>
                    </p>
                  )}
                  {a.orcid && (
                    <p>
                      <a
                        href={`https://orcid.org/${a.orcid}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-coral transition-colors"
                      >
                        ORCID {a.orcid}
                      </a>
                    </p>
                  )}
                </div>
              )}
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>
