---
// Gallery — 그룹 사진 + 학회/시상 등 행사 사진
// 데이터: src/content/gallery-events/*.md (Astro Content Collection)
// 사진 업로드 규칙: src/assets/gallery/README.md 참고
import BaseLayout from '@layouts/BaseLayout.astro';
import PhotoMosaic from '@components/PhotoMosaic.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type GalleryEvent = CollectionEntry<'gallery-events'>['data'];

const galleryEvents = (await getCollection('gallery-events'))
  .map((e) => e.data)
  .sort((a, b) => a.order - b.order);

const byYear = galleryEvents.reduce<Record<number, GalleryEvent[]>>(
  (acc, ev) => {
    (acc[ev.year] ??= []).push(ev);
    return acc;
  },
  {}
);

const years = Object.keys(byYear)
  .map(Number)
  .sort((a, b) => b - a);

const totalEvents = galleryEvents.length;
const totalPhotos = galleryEvents.reduce((sum, ev) => sum + ev.photoCount, 0);
---

<BaseLayout
  title="Gallery · SKKU-STEM Lab"
  description="Group photos from SKKU-STEM Lab events, conferences, awards, and gatherings."
>
  <div class="section-stack pb-24 md:pb-32">
    {/* ─────────────── Page header ─────────────── */}
    <section class="container-page pt-12 md:pt-20">
      <div class="max-w-2xl">
        <p class="font-mono text-xs uppercase tracking-[0.16em] text-coral">
          Gallery
        </p>
        <h1
          class="mt-6 font-display font-normal tracking-tight text-5xl md:text-6xl leading-[1.05]"
        >
          Group photos
        </h1>
        <p class="mt-7 text-base md:text-lg text-ink/75 leading-relaxed">
          <span class="font-mono tabular-nums text-ink">{totalEvents}</span>{' '}
          events &middot;{' '}
          <span class="font-mono tabular-nums text-ink">{totalPhotos}</span>{' '}
          photos &mdash; lab gatherings, conferences, awards, and graduations
          from {years[years.length - 1]} to {years[0]}.
        </p>
      </div>
    </section>

    {/* ─────────────── Year jump nav ─────────────── */}
    <section class="container-page">
      <nav
        aria-label="Jump to year"
        class="flex flex-wrap items-baseline gap-x-3 gap-y-2 pb-6 border-b border-ink/15"
      >
        <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink/55 mr-2">
          Jump
        </span>
        {
          years.map((year) => (
            <a
              href={`#year-${year}`}
              class="font-mono text-sm tabular-nums text-ink/70 hover:text-coral transition-colors"
            >
              {year}
            </a>
          ))
        }
      </nav>
    </section>

    {/* ─────────────── Year-grouped events ─────────────── */}
    <section class="container-page">
      <div class="space-y-12 md:space-y-16">
        {
          years.map((year) => (
            <div class="grid md:grid-cols-[5rem_1fr] gap-x-8 lg:gap-x-12">
              <h2
                id={`year-${year}`}
                class="md:sticky md:top-20 self-start scroll-mt-20 font-display font-normal text-3xl md:text-4xl tracking-tight tabular-nums text-coral"
              >
                {year}
              </h2>

              <div class="space-y-12 md:space-y-14">
                {byYear[year].map((event) => (
                  <article>
                    {/* Event header */}
                    <header>
                      <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-coral font-bold">
                        {event.date}
                      </p>
                      <h3 class="mt-2 font-display font-normal text-xl md:text-2xl tracking-tight leading-snug">
                        {event.title}
                      </h3>
                      {event.titleEn && (
                        <p class="mt-1 text-sm text-ink/55 italic">
                          {event.titleEn}
                        </p>
                      )}
                      {event.location && (
                        <p class="mt-2 text-sm text-ink/65">
                          {event.location}
                        </p>
                      )}
                      {event.participants && (
                        <p class="mt-2 text-xs text-ink/65 leading-relaxed">
                          <span class="font-mono uppercase tracking-wider text-ink/45 mr-1">
                            People:
                          </span>
                          {event.participants}
                        </p>
                      )}
                      {event.awards && (
                        <p class="mt-1.5 text-xs text-ink/80 leading-relaxed">
                          <span class="font-mono uppercase tracking-wider text-coral mr-1">
                            Awards:
                          </span>
                          {event.awards}
                        </p>
                      )}
                    </header>

                    {/* Photo mosaic (1-6 photos in fixed-aspect container, click to enlarge) */}
                    {event.photoCount > 0 && (
                      <div class="mt-6">
                        <PhotoMosaic
                          slug={event.slug}
                          count={event.photoCount}
                          alt={event.title}
                        />
                      </div>
                    )}
                  </article>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
