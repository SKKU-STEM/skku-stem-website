---
// Publications · Non-SCI & Patents
// 데이터: src/content/publications/non-sci-patents.json (kind 필드로 종류 구분)
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { formatChemistry } from '@/utils/chemistry';

type NonSciOrPatent = CollectionEntry<'publications-non-sci-patents'>['data'];

const nonSciAndPatents = (await getCollection('publications-non-sci-patents'))
  .map((e) => e.data)
  .sort((a, b) => b.number - a.number);

const byYear = nonSciAndPatents.reduce<Record<number, NonSciOrPatent[]>>(
  (acc, item) => {
    (acc[item.year] ??= []).push(item);
    return acc;
  },
  {}
);

const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);

const total = nonSciAndPatents.length;
const patentCount = nonSciAndPatents.filter((i) => i.kind === 'patent').length;
const nonSciCount = nonSciAndPatents.filter((i) => i.kind === 'non-sci').length;
const bookCount = nonSciAndPatents.filter((i) => i.kind === 'book').length;
---

<BaseLayout
  title="Publications · Non-SCI & Patents · SKKU-STEM Lab"
  description="Non-SCI publications, books, and patents from the SKKU-STEM Laboratory."
>
  <div class="section-stack pb-24 md:pb-32">
    {/* ─────────────── Page header ─────────────── */}
    <section class="container-page pt-12 md:pt-20">
      <div class="max-w-3xl">
        <p class="font-mono text-xs uppercase tracking-[0.16em] text-coral">
          <a
            href="/publications"
            class="text-ink/55 hover:text-coral transition-colors"
          >
            Publications
          </a>
          <span class="mx-1.5 text-ink/30" aria-hidden="true">/</span>
          Non-SCI &amp; Patents
        </p>
        <h1
          class="mt-6 font-display font-normal tracking-tight text-5xl md:text-6xl leading-[1.05]"
        >
          Non-SCI &amp; Patents
        </h1>
        <p class="mt-7 text-base md:text-lg text-ink/75 leading-relaxed">
          <span class="font-mono tabular-nums text-ink">{total}</span> items
          mixing non-SCI papers, technical reports, translated books, and
          patents (Korea + USA), in reverse chronological order.
        </p>
        <p class="mt-3 text-xs text-ink/55 italic">
          <span class="tabular-nums">{patentCount}</span> patents,{' '}
          <span class="tabular-nums">{nonSciCount}</span> non-SCI publications,{' '}
          <span class="tabular-nums">{bookCount}</span> book.
        </p>
      </div>
    </section>

    {/* ─────────────── Sub-page nav ─────────────── */}
    <section class="container-page">
      <nav
        aria-label="Publications sections"
        class="flex flex-wrap items-baseline gap-x-3 gap-y-3 pb-8 border-b border-ink/20"
      >
        <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink/55 mr-2">
          Sections
        </span>
        <a
          href="/publications"
          class="inline-flex items-center px-3 py-1.5 border border-ink/20 text-sm text-ink/75 hover:border-ink/40 hover:text-ink transition-colors"
        >
          SCI (2016–present)
        </a>
        <a
          href="/publications/before-skku"
          class="inline-flex items-center px-3 py-1.5 border border-ink/20 text-sm text-ink/75 hover:border-ink/40 hover:text-ink transition-colors"
        >
          Before SKKU (2000–2015)
        </a>
        <span
          class="inline-flex items-center px-3 py-1.5 border border-ink/30 text-sm font-medium text-ink"
          aria-current="page"
        >
          Non-SCI &amp; Patents
        </span>
      </nav>
    </section>

    {/* ─────────────── Year jump nav ─────────────── */}
    <section class="container-page">
      <nav
        aria-label="Jump to year"
        class="flex flex-wrap items-baseline gap-x-3 gap-y-2 pb-6 border-b border-ink/15"
      >
        <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink/55 mr-2">
          Jump
        </span>
        {
          years.map((year) => (
            <a
              href={`#year-${year}`}
              class="font-mono text-sm tabular-nums text-ink/70 hover:text-coral transition-colors"
            >
              {year}
            </a>
          ))
        }
      </nav>
    </section>

    {/* ─────────────── Year-grouped list ─────────────── */}
    <section class="container-page">
      <div class="space-y-10">
        {
          years.map((year) => (
            <div class="grid md:grid-cols-[5rem_1fr] gap-x-6 lg:gap-x-10">
              <h2
                id={`year-${year}`}
                class="md:sticky md:top-20 self-start scroll-mt-20 font-display font-normal text-3xl md:text-4xl tracking-tight tabular-nums text-coral"
              >
                {year}
              </h2>

              <ol class="divide-y divide-ink/15">
                {byYear[year].map((item) => (
                  <li class="py-3 grid grid-cols-[2.5rem_1fr] gap-x-4">
                    <span class="font-mono text-sm tabular-nums text-right pt-0.5 text-ink/40">
                      {item.number}
                    </span>
                    <div>
                      {/* header line: kind label + journal/region/publisher */}
                      {item.kind === 'non-sci' ? (
                        <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-coral font-bold">
                          {item.journal}
                          {item.volumePages && (
                            <span class="text-ink/50 normal-case font-normal ml-1.5">
                              &middot; {item.volumePages}
                            </span>
                          )}
                        </p>
                      ) : item.kind === 'patent' ? (
                        <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-coral font-bold">
                          Patent
                          {item.region && (
                            <span class="ml-1.5">&middot; {item.region}</span>
                          )}
                          {item.status && (
                            <span class="ml-1.5 font-normal text-ink/55">
                              &middot; {item.status}
                            </span>
                          )}
                        </p>
                      ) : (
                        <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-coral font-bold">
                          Book
                          {item.publisher && (
                            <span class="text-ink/50 normal-case font-normal ml-1.5">
                              &middot; {item.publisher}
                            </span>
                          )}
                        </p>
                      )}

                      {/* title — common */}
                      <p class="mt-1.5 text-sm md:text-base leading-snug font-serif text-ink/95">
                        {item.link ? (
                          <a
                            href={item.link}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="hover:text-coral transition-colors"
                            set:html={formatChemistry(item.title)}
                          />
                        ) : (
                          <Fragment set:html={formatChemistry(item.title)} />
                        )}
                        {item.titleEn && (
                          <span
                            class="ml-1.5 text-ink/55 italic"
                            set:html={`(${formatChemistry(item.titleEn)})`}
                          />
                        )}
                      </p>

                      {/* authors / inventors */}
                      <p class="mt-1.5 text-xs text-ink/60 leading-relaxed">
                        {item.kind === 'patent' ? (
                          <Fragment>
                            <span class="font-mono uppercase tracking-wider text-ink/45 mr-1">
                              Inventors:
                            </span>
                            {item.inventors}
                          </Fragment>
                        ) : (
                          item.authors
                        )}
                      </p>

                      {/* patent metadata */}
                      {item.kind === 'patent' && (
                        <p class="mt-1.5 font-mono text-[10px] uppercase tracking-[0.14em] text-ink/55 leading-relaxed">
                          {item.patentNo && <Fragment>Patent No. {item.patentNo}</Fragment>}
                          {item.applicationNo && (
                            <Fragment>
                              Appl. {item.applicationNo}
                              {item.applicationDate && ` (${item.applicationDate})`}
                            </Fragment>
                          )}
                          {item.registrationNo &&
                            (item.applicationNo || item.patentNo) && (
                              <Fragment>
                                {' '}&middot; Reg. {item.registrationNo}
                                {item.registrationDate && ` (${item.registrationDate})`}
                              </Fragment>
                            )}
                          {item.registrationNo &&
                            !item.applicationNo &&
                            !item.patentNo && (
                              <Fragment>
                                Reg. {item.registrationNo}
                                {item.registrationDate && ` (${item.registrationDate})`}
                              </Fragment>
                            )}
                        </p>
                      )}

                      {/* book metadata */}
                      {item.kind === 'book' && (
                        <p class="mt-1.5 font-mono text-[10px] uppercase tracking-[0.14em] text-ink/55">
                          {item.isbn && <Fragment>ISBN {item.isbn}</Fragment>}
                          {item.publicationDate && (
                            <Fragment>
                              {item.isbn && ' · '}
                              {item.publicationDate}
                            </Fragment>
                          )}
                        </p>
                      )}

                    </div>
                  </li>
                ))}
              </ol>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
