---
// Publications — SKKU 시기 SCI 논문 (메인 페이지)
// 데이터: src/content/publications/skku.json (Astro Content Collection)
// 하위 페이지: /publications/before-skku, /publications/non-sci-patents
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { formatChemistry } from '@/utils/chemistry';

type Publication = CollectionEntry<'publications-skku'>['data'];

const skkuPublications = (await getCollection('publications-skku'))
  .map((e) => e.data)
  .sort((a, b) => b.number - a.number);

// before-SKKU 컬렉션은 본 페이지에 리스트로 표시하지 않고 전체 경력 통계용으로만 합산
const preSkkuPublications = (await getCollection('publications-before-skku'))
  .map((e) => e.data);

// 연도별 그룹핑 (SKKU 기간만 본 페이지에 표시)
const byYear = skkuPublications.reduce<Record<number, Publication[]>>(
  (acc, p) => {
    (acc[p.year] ??= []).push(p);
    return acc;
  },
  {}
);

const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);

const total = skkuPublications.length;
const leadCount = skkuPublications.filter((p) => p.lead).length;
const coCount = total - leadCount;
const minYear = Math.min(...years);
const maxYear = Math.max(...years);

// 전체 경력 (pre-SKKU + SKKU) — 컬렉션 길이/연도/lead 필드로 build-time 자동 산출
const grandTotal = skkuPublications.length + preSkkuPublications.length;
const grandLeadCount = leadCount + preSkkuPublications.filter((p) => p.lead).length;
const grandCoCount = grandTotal - grandLeadCount;
const grandMinYear = Math.min(
  ...years,
  ...preSkkuPublications.map((p) => p.year),
);
---

<BaseLayout
  title="Publications · SKKU-STEM Lab"
  description="Peer-reviewed publications from the SKKU-STEM Laboratory at Sungkyunkwan University."
>
  <div class="section-stack pb-24 md:pb-32">
    {/* ─────────────── Page header ─────────────── */}
    <section class="container-page pt-12 md:pt-20 relative">
      {/* 배경 그래픽 — 5장 부채꼴로 겹친 논문 스택. 페이지 안에 title bar + 본문 라인.
          1장은 coral featured (lead authorship 상징). 우측 비대칭 배치로 좌측 텍스트 가독성 확보. */}
      <svg
        viewBox="0 0 800 280"
        preserveAspectRatio="xMaxYMid slice"
        class="absolute inset-0 w-full h-full pointer-events-none"
        aria-hidden="true"
      >
        <defs>
          {/* Body text lines — 페이지 1장 안의 본문 텍스트 라인 패턴 (재사용) */}
          <path
            id="paper-lines"
            d="M -40 -25 L 40 -25 M -40 -17 L 35 -17 M -40 -9 L 40 -9 M -40 -1 L 28 -1 M -40 11 L 40 11 M -40 19 L 38 19 M -40 27 L 40 27 M -40 35 L 26 35 M -40 47 L 40 47 M -40 55 L 34 55"
            fill="none"
            stroke-width="0.5"
          />
        </defs>

        {/* Paper 5 — 가장 뒤, 우측에 살짝 삐져나온 페이지 */}
        <g transform="translate(760 188) rotate(20)">
          <rect x="-50" y="-67.5" width="100" height="135" fill="#F1EFE7" fill-opacity="0.55" stroke="#141413" stroke-width="0.7" stroke-opacity="0.22" />
          <rect x="-40" y="-55" width="62" height="3" fill="#141413" opacity="0.28" />
          <line x1="-40" y1="-44" x2="-8" y2="-44" stroke="#141413" stroke-width="0.6" opacity="0.22" />
          <use href="#paper-lines" stroke="#141413" opacity="0.20" />
        </g>

        {/* Paper 1 — 좌측 깊은 페이지 */}
        <g transform="translate(528 178) rotate(-12)">
          <rect x="-50" y="-67.5" width="100" height="135" fill="#F1EFE7" fill-opacity="0.55" stroke="#141413" stroke-width="0.7" stroke-opacity="0.22" />
          <rect x="-40" y="-55" width="62" height="3" fill="#141413" opacity="0.28" />
          <line x1="-40" y1="-44" x2="-8" y2="-44" stroke="#141413" stroke-width="0.6" opacity="0.22" />
          <use href="#paper-lines" stroke="#141413" opacity="0.20" />
        </g>

        {/* Paper 2 — 중간-좌측 */}
        <g transform="translate(595 162) rotate(5)">
          <rect x="-50" y="-67.5" width="100" height="135" fill="#F1EFE7" fill-opacity="0.55" stroke="#141413" stroke-width="0.7" stroke-opacity="0.22" />
          <rect x="-40" y="-55" width="62" height="3" fill="#141413" opacity="0.28" />
          <line x1="-40" y1="-44" x2="-8" y2="-44" stroke="#141413" stroke-width="0.6" opacity="0.22" />
          <use href="#paper-lines" stroke="#141413" opacity="0.20" />
        </g>

        {/* Paper 3 — 중간-우측 */}
        <g transform="translate(660 148) rotate(-4)">
          <rect x="-50" y="-67.5" width="100" height="135" fill="#F1EFE7" fill-opacity="0.55" stroke="#141413" stroke-width="0.7" stroke-opacity="0.22" />
          <rect x="-40" y="-55" width="62" height="3" fill="#141413" opacity="0.28" />
          <line x1="-40" y1="-44" x2="-8" y2="-44" stroke="#141413" stroke-width="0.6" opacity="0.22" />
          <use href="#paper-lines" stroke="#141413" opacity="0.20" />
        </g>

        {/* Paper 4 — FEATURED top (lead authorship 강조, coral) */}
        <g transform="translate(712 132) rotate(9)">
          <rect x="-50" y="-67.5" width="100" height="135" fill="#CC785C" fill-opacity="0.10" stroke="#CC785C" stroke-width="0.85" stroke-opacity="0.50" />
          <rect x="-40" y="-55" width="62" height="3" fill="#CC785C" opacity="0.55" />
          <line x1="-40" y1="-44" x2="-8" y2="-44" stroke="#CC785C" stroke-width="0.6" opacity="0.45" />
          <use href="#paper-lines" stroke="#CC785C" opacity="0.42" />
        </g>
      </svg>

      <div class="relative max-w-3xl">
        <p class="font-mono text-xs uppercase tracking-[0.16em] text-coral-700">
          Publications
        </p>
        <h1
          class="mt-6 font-display font-normal tracking-tight text-5xl md:text-6xl leading-[1.05]"
        >
          Publications
        </h1>
        <p class="mt-7 text-base md:text-lg text-ink/75 leading-relaxed">
          <span class="font-mono tabular-nums text-ink">{grandTotal}</span> SCI
          papers across the full career ({grandMinYear}&ndash;{maxYear})
          <br />
          &mdash;{' '}
          <span class="text-coral font-medium tabular-nums">{grandLeadCount}</span>{' '}
          lead authorship &amp;{' '}
          <span class="text-ink/85 tabular-nums">{grandCoCount}</span>{' '}
          co-authorship
        </p>
        <p class="mt-3 text-base md:text-lg text-ink/75 leading-relaxed">
          <span class="font-mono tabular-nums text-ink">{total}</span> SCI papers
          since {minYear} at SKKU
          &mdash;{' '}
          <span class="text-coral font-medium tabular-nums">{leadCount}</span>{' '}
          lead authorship &amp;{' '}
          <span class="text-ink/85 tabular-nums">{coCount}</span>{' '}
          co-authorship
        </p>
      </div>
    </section>

    {/* ─────────────── Sub-page nav ─────────────── */}
    <section class="container-page">
      <nav
        aria-label="Publications sections"
        class="flex flex-wrap items-baseline gap-x-3 gap-y-3 pb-8 border-b border-ink/20"
      >
        <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink/70 mr-2">
          Sections
        </span>
        <span
          class="inline-flex items-center px-3 py-1.5 border border-ink/30 text-sm font-medium text-ink"
          aria-current="page"
        >
          SCI ({minYear}&ndash;{maxYear})
        </span>
        <a
          href="/publications/before-skku"
          class="inline-flex items-center px-3 py-1.5 border border-ink/20 text-sm text-ink/75 hover:border-ink/40 hover:text-ink transition-colors"
        >
          Before SKKU (2000&ndash;2015)
        </a>
        <a
          href="/publications/non-sci-patents"
          class="inline-flex items-center px-3 py-1.5 border border-ink/20 text-sm text-ink/75 hover:border-ink/40 hover:text-ink transition-colors"
        >
          Non-SCI &amp; Patents
        </a>
      </nav>
    </section>

    {/* ─────────────── Year jump nav ─────────────── */}
    <section class="container-page">
      <nav
        aria-label="Jump to year"
        class="flex flex-wrap items-baseline gap-x-3 gap-y-2 pb-6 border-b border-ink/15"
      >
        <span
          class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink/70 mr-2"
        >
          Jump
        </span>
        {
          years.map((year) => (
            <a
              href={`#year-${year}`}
              class="font-mono text-sm tabular-nums text-ink/70 hover:text-coral transition-colors"
            >
              {year}
            </a>
          ))
        }
      </nav>
    </section>

    {/* ─────────────── Year-grouped list ─────────────── */}
    <section class="container-page">
      <div class="space-y-10">
        {
          years.map((year) => (
            <div class="grid md:grid-cols-[5rem_1fr] gap-x-6 lg:gap-x-10">
              <h2
                id={`year-${year}`}
                class="md:sticky md:top-20 self-start scroll-mt-20 font-display font-normal text-3xl md:text-4xl tracking-tight tabular-nums text-coral"
              >
                {year}
              </h2>

              <ol class="divide-y divide-ink/15">
                {byYear[year].map((p) => (
                  <li class="py-3 grid grid-cols-[2.5rem_1fr] gap-x-4">
                    <span
                      class:list={[
                        'font-mono text-sm tabular-nums text-right pt-0.5',
                        p.lead ? 'text-coral font-medium' : 'text-ink/65',
                      ]}
                    >
                      {p.number}
                    </span>
                    <div>
                      <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-coral font-bold">
                        {p.journal}
                        {p.volumePages && (
                          <span class="text-ink/65 normal-case font-normal ml-1.5">
                            &middot; {p.volumePages}
                          </span>
                        )}
                      </p>
                      <p class="mt-1.5 text-sm md:text-base leading-snug font-serif text-ink/95">
                        {p.doi ? (
                          <a
                            href={p.doi}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="hover:text-coral transition-colors"
                            set:html={formatChemistry(p.title)}
                          />
                        ) : (
                          <Fragment set:html={formatChemistry(p.title)} />
                        )}
                      </p>
                      <p class="mt-1.5 text-xs text-ink/60 leading-relaxed">
                        {p.authors}
                      </p>
                    </div>
                  </li>
                ))}
              </ol>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
