---
// Publications · Before SKKU (2000–2015)
// 데이터: src/content/publications/before-skku.json (Astro Content Collection)
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { formatChemistry } from '@/utils/chemistry';

type Publication = CollectionEntry<'publications-before-skku'>['data'];

const preSkkuPublications = (await getCollection('publications-before-skku'))
  .map((e) => e.data)
  .sort((a, b) => b.number - a.number);

const byYear = preSkkuPublications.reduce<Record<number, Publication[]>>(
  (acc, p) => {
    (acc[p.year] ??= []).push(p);
    return acc;
  },
  {}
);

const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);

const total = preSkkuPublications.length;
const leadCount = preSkkuPublications.filter((p) => p.lead).length;
const coCount = total - leadCount;
const minYear = Math.min(...years);
const maxYear = Math.max(...years);
---

<BaseLayout
  title="Publications · Before SKKU · SKKU-STEM Lab"
  description="Pre-SKKU peer-reviewed publications (2000–2015) from Young-Min Kim's earlier career."
>
  <div class="section-stack pb-24 md:pb-32">
    {/* ─────────────── Page header ─────────────── */}
    <section class="container-page pt-12 md:pt-20">
      <div class="max-w-3xl">
        <p class="font-mono text-xs uppercase tracking-[0.16em] text-coral-700">
          <a
            href="/publications"
            class="text-ink/80 hover:text-coral underline underline-offset-2 transition-colors"
          >
            Publications
          </a>
          <span class="mx-1.5 text-ink/65" aria-hidden="true">/</span>
          Before SKKU
        </p>
        <h1
          class="mt-6 font-display font-normal tracking-tight text-5xl md:text-6xl leading-[1.05]"
        >
          Before SKKU
        </h1>
        <p class="mt-7 text-base md:text-lg text-ink/75 leading-relaxed">
          <span class="font-mono tabular-nums text-ink">{total}</span> SCI
          papers from {minYear}&ndash;{maxYear}, the period before joining the
          Department of Energy Science at SKKU as faculty in 2016. Includes
          graduate work at Seoul National University, Ph.D. at KAIST, and the
          ORNL postdoctoral fellowship.
        </p>
        <p class="mt-3 text-xs text-ink/70 italic">
          <span class="text-coral-700 font-medium tabular-nums">{leadCount}</span>{' '}
          lead-authored,{' '}
          <span class="tabular-nums">{coCount}</span> co-authored.
        </p>
      </div>
    </section>

    {/* ─────────────── Sub-page nav ─────────────── */}
    <section class="container-page">
      <nav
        aria-label="Publications sections"
        class="flex flex-wrap items-baseline gap-x-3 gap-y-3 pb-8 border-b border-ink/20"
      >
        <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink/70 mr-2">
          Sections
        </span>
        <a
          href="/publications"
          class="inline-flex items-center px-3 py-1.5 border border-ink/20 text-sm text-ink/75 hover:border-ink/40 hover:text-ink transition-colors"
        >
          SCI (2016–present)
        </a>
        <span
          class="inline-flex items-center px-3 py-1.5 border border-ink/30 text-sm font-medium text-ink"
          aria-current="page"
        >
          Before SKKU ({minYear}&ndash;{maxYear})
        </span>
        <a
          href="/publications/non-sci-patents"
          class="inline-flex items-center px-3 py-1.5 border border-ink/20 text-sm text-ink/75 hover:border-ink/40 hover:text-ink transition-colors"
        >
          Non-SCI &amp; Patents
        </a>
      </nav>
    </section>

    {/* ─────────────── Year jump nav ─────────────── */}
    <section class="container-page">
      <nav
        aria-label="Jump to year"
        class="flex flex-wrap items-baseline gap-x-3 gap-y-2 pb-6 border-b border-ink/15"
      >
        <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink/70 mr-2">
          Jump
        </span>
        {
          years.map((year) => (
            <a
              href={`#year-${year}`}
              class="font-mono text-sm tabular-nums text-ink/70 hover:text-coral transition-colors"
            >
              {year}
            </a>
          ))
        }
      </nav>
    </section>

    {/* ─────────────── Year-grouped list ─────────────── */}
    <section class="container-page">
      <div class="space-y-10">
        {
          years.map((year) => (
            <div class="grid md:grid-cols-[5rem_1fr] gap-x-6 lg:gap-x-10">
              <h2
                id={`year-${year}`}
                class="md:sticky md:top-20 self-start scroll-mt-20 font-display font-normal text-3xl md:text-4xl tracking-tight tabular-nums text-coral"
              >
                {year}
              </h2>

              <ol class="divide-y divide-ink/15">
                {byYear[year].map((p) => (
                  <li class="py-3 grid grid-cols-[2.5rem_1fr] gap-x-4">
                    <span
                      class:list={[
                        'font-mono text-sm tabular-nums text-right pt-0.5',
                        p.lead ? 'text-coral-700 font-medium' : 'text-ink/65',
                      ]}
                    >
                      {p.number}
                    </span>
                    <div>
                      <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-coral-700 font-bold">
                        {p.journal}
                        {p.volumePages && (
                          <span class="text-ink/65 normal-case font-normal ml-1.5">
                            &middot; {p.volumePages}
                          </span>
                        )}
                      </p>
                      <p class="mt-1.5 text-sm md:text-base leading-snug font-serif text-ink/95">
                        {p.doi ? (
                          <a
                            href={p.doi}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="hover:text-coral transition-colors"
                            set:html={formatChemistry(p.title)}
                          />
                        ) : (
                          <Fragment set:html={formatChemistry(p.title)} />
                        )}
                      </p>
                      <p class="mt-1.5 text-xs text-ink/60 leading-relaxed">
                        {p.authors}
                      </p>
                    </div>
                  </li>
                ))}
              </ol>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
