---
// News — 연구실 게시판 (논문/수상/이벤트/멤버 소식 등)
// 데이터: src/content/news/*.md (Astro Content Collection)
// 사진 업로드: src/assets/news/README.md 참고
import BaseLayout from '@layouts/BaseLayout.astro';
import NewsPhoto from '@components/NewsPhoto.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type NewsEntry = CollectionEntry<'news'>['data'];
type NewsCategory = NewsEntry['category'];

const CATEGORY_LABELS: Record<NewsCategory, string> = {
  paper: 'Paper',
  award: 'Award',
  media: 'Media',
  member: 'Member',
  event: 'Event',
  grant: 'Grant',
  lab: 'Lab',
};

const newsEntries = (await getCollection('news'))
  .map((e) => e.data)
  .sort((a, b) => a.order - b.order);

const byYear = newsEntries.reduce<Record<number, NewsEntry[]>>((acc, e) => {
  (acc[e.year] ??= []).push(e);
  return acc;
}, {});

const years = Object.keys(byYear)
  .map(Number)
  .sort((a, b) => b - a);
---

<BaseLayout
  title="News · SKKU-STEM Lab"
  description="Recent papers, awards, talks, member milestones, and lab events from the SKKU-STEM Laboratory."
>
  <div class="section-stack pb-24 md:pb-32">
    {/* ─────────────── Page header ─────────────── */}
    <section class="container-page pt-12 md:pt-20 relative">
      {/* 배경 그래픽 — 가로 timeline + event ticks/dots. 6개 year marker + 다양한 높이의 event tick,
          axis 위/아래에 분산된 dot, 4개 coral featured milestone. News의 chronological 특성을 시각화. */}
      <svg
        viewBox="0 0 800 200"
        preserveAspectRatio="xMidYMid slice"
        class="absolute inset-0 w-full h-full pointer-events-none"
        aria-hidden="true"
      >
        <defs>
          <radialGradient id="news-glow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#CC785C" stop-opacity="0.30" />
            <stop offset="60%" stop-color="#CC785C" stop-opacity="0.06" />
            <stop offset="100%" stop-color="#CC785C" stop-opacity="0" />
          </radialGradient>
        </defs>

        {/* Timeline axis — 가로 main line */}
        <line x1="40" y1="130" x2="760" y2="130" class="stroke-ink" stroke-width="0.7" opacity="0.30" />

        {/* Year markers — 6개 tall vertical ticks (axis 위로 솟음) */}
        <path
          fill="none"
          class="stroke-ink"
          stroke-width="1.0"
          opacity="0.35"
          d="M 80 70 L 80 130 M 220 70 L 220 130 M 360 70 L 360 130 M 500 70 L 500 130 M 640 70 L 640 130 M 760 70 L 760 130"
        />

        {/* Event short ticks — axis에서 dot까지 연결 (event 발생 줄기) */}
        <path
          fill="none"
          class="stroke-ink"
          stroke-width="0.5"
          opacity="0.35"
          d="M 110 130 L 110 105 M 145 130 L 145 92 M 175 130 L 175 110 M 250 130 L 250 100 M 285 130 L 285 80 M 315 130 L 315 112 M 395 130 L 395 95 M 425 130 L 425 78 M 540 130 L 540 105 M 575 130 L 575 88 M 670 130 L 670 100 M 700 130 L 700 82"
        />

        {/* Featured event ticks — axis에서 coral milestone까지 연결선 */}
        <path
          fill="none"
          class="stroke-coral"
          stroke-width="0.85"
          opacity="0.40"
          d="M 190 130 L 190 73 M 345 130 L 345 117 M 475 130 L 475 81 M 650 130 L 650 95"
        />

        {/* Event dots — axis 위/아래 분산된 일반 event 표시 */}
        <g class="fill-ink" opacity="0.45">
          <circle cx="110" cy="105" r="2" />
          <circle cx="145" cy="92" r="2" />
          <circle cx="175" cy="110" r="2" />
          <circle cx="250" cy="100" r="2" />
          <circle cx="285" cy="80" r="2" />
          <circle cx="315" cy="112" r="2" />
          <circle cx="395" cy="95" r="2" />
          <circle cx="425" cy="78" r="2" />
          <circle cx="540" cy="105" r="2" />
          <circle cx="575" cy="88" r="2" />
          <circle cx="670" cy="100" r="2" />
          <circle cx="700" cy="82" r="2" />
          <circle cx="130" cy="148" r="1.7" />
          <circle cx="200" cy="155" r="1.7" />
          <circle cx="270" cy="148" r="1.7" />
          <circle cx="370" cy="152" r="1.7" />
          <circle cx="450" cy="148" r="1.7" />
          <circle cx="520" cy="155" r="1.7" />
          <circle cx="600" cy="148" r="1.7" />
          <circle cx="710" cy="152" r="1.7" />
        </g>

        {/* Featured milestones — coral with glow (4개 주요 event) */}
        <circle cx="190" cy="70" r="13" fill="url(#news-glow)" />
        <circle cx="190" cy="70" r="3.3" fill="#CC785C" />
        <circle cx="345" cy="115" r="13" fill="url(#news-glow)" />
        <circle cx="345" cy="115" r="3.3" fill="#CC785C" />
        <circle cx="475" cy="78" r="13" fill="url(#news-glow)" />
        <circle cx="475" cy="78" r="3.3" fill="#CC785C" />
        <circle cx="650" cy="92" r="13" fill="url(#news-glow)" />
        <circle cx="650" cy="92" r="3.3" fill="#CC785C" />
      </svg>

      <div class="relative max-w-2xl">
        <p class="font-mono text-xs uppercase tracking-[0.16em] text-coral">
          News
        </p>
        <h1
          class="mt-6 font-display font-normal tracking-tight text-5xl md:text-6xl leading-[1.05]"
        >
          Lab notes
        </h1>
        <p class="mt-7 text-base md:text-lg text-ink/75 leading-relaxed">
          Recent papers, awards, talks, member milestones, and lab events.
        </p>
      </div>
    </section>

    {/* ─────────────── Year jump nav ─────────────── */}
    <section class="container-page">
      <nav
        aria-label="Jump to year"
        class="flex flex-wrap items-baseline gap-x-3 gap-y-2 pb-6 border-b border-ink/15"
      >
        <span
          class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink/55 mr-2"
        >
          Jump
        </span>
        {
          years.map((year) => (
            <a
              href={`#year-${year}`}
              class="font-mono text-sm tabular-nums text-ink/70 hover:text-coral transition-colors"
            >
              {year}
            </a>
          ))
        }
      </nav>
    </section>

    {/* ─────────────── Year-grouped timeline ─────────────── */}
    <section class="container-page">
      <div class="space-y-12 md:space-y-16">
        {
          years.map((year) => (
            <div class="grid md:grid-cols-[5rem_1fr] gap-x-8 lg:gap-x-12">
              <h2
                id={`year-${year}`}
                class="md:sticky md:top-20 self-start scroll-mt-20 font-display font-normal text-3xl md:text-4xl tracking-tight tabular-nums text-coral"
              >
                {year}
              </h2>

              <div class="space-y-10 md:space-y-14">
                {byYear[year].map((entry) => {
                  const count = entry.photoCount ?? 0;
                  return (
                    <article
                      id={`news-${entry.slug}`}
                      class:list={[
                        'scroll-mt-20',
                        entry.featured &&
                          'relative border-l-4 border-coral bg-cream-200/70 pl-6 md:pl-7 pr-5 md:pr-6 py-6 md:py-7 rounded-r-md -ml-1',
                      ]}
                    >
                      {/* Date · Category meta */}
                      <p class="font-mono text-[11px] uppercase tracking-[0.16em]">
                        <time class="text-coral font-bold">{entry.date}</time>
                        <span class="mx-1.5 text-ink/30" aria-hidden="true">
                          &middot;
                        </span>
                        <span class="text-ink/55">
                          {CATEGORY_LABELS[entry.category]}
                        </span>
                        {entry.featured && (
                          <span class="ml-3 inline-flex items-center gap-1 text-coral">
                            <span aria-hidden="true">&#9733;</span>
                            <span>Featured</span>
                          </span>
                        )}
                      </p>

                      {/* Headline */}
                      <h3
                        class:list={[
                          'mt-3 font-display font-normal tracking-tight leading-snug text-balance',
                          entry.featured
                            ? 'text-2xl md:text-3xl'
                            : 'text-xl md:text-2xl',
                        ]}
                      >
                        {entry.headline}
                      </h3>

                      {/* Body */}
                      {entry.body && (
                        <p
                          class:list={[
                            'mt-3 leading-relaxed text-ink/85',
                            entry.featured
                              ? 'text-base md:text-lg font-serif'
                              : 'text-base',
                          ]}
                        >
                          {entry.body}
                        </p>
                      )}

                      {/* Photos */}
                      {count > 0 && (
                        <div
                          class:list={[
                            'mt-5 grid gap-3',
                            count === 1
                              ? 'grid-cols-1'
                              : 'grid-cols-2',
                          ]}
                        >
                          {Array.from({ length: count }, (_, i) => (
                            <NewsPhoto
                              slug={entry.slug}
                              index={i + 1}
                              alt={`${entry.headline} — photo ${i + 1}`}
                              class={
                                count === 3 && i === 0
                                  ? 'col-span-2'
                                  : undefined
                              }
                            />
                          ))}
                        </div>
                      )}

                      {/* Links */}
                      {entry.links && entry.links.length > 0 && (
                        <div class="mt-4 flex flex-wrap gap-x-5 gap-y-2">
                          {entry.links.map((link) => (
                            <a
                              href={link.href}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="text-[11px] uppercase tracking-[0.14em] text-ink/65 hover:text-coral inline-flex items-center gap-1 transition-colors"
                            >
                              {link.label}{' '}
                              <span aria-hidden="true">&rarr;</span>
                            </a>
                          ))}
                        </div>
                      )}
                    </article>
                  );
                })}
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
