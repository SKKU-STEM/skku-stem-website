---
// SKKU-STEM 로고 — 좌: 심볼 마크 (public/logo.png을 CSS mask로 사용해 coral로 채움) + 우: 텍스트 워드마크
// 원본 PNG는 194×228 (5:6 portrait). bg-coral과 mask로 배경 투명 + coral 단색 처리.
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<span class:list={['inline-flex items-center gap-2 sm:gap-2.5', className]}>
  <span
    class="block h-full bg-coral shrink-0 aspect-[194/228]"
    style="mask: url(/logo-mark.png) no-repeat center / contain; -webkit-mask: url(/logo-mark.png) no-repeat center / contain;"
    aria-hidden="true"
  ></span>
  <span
    class="font-sans text-base sm:text-lg font-semibold tracking-tight whitespace-nowrap"
  >
    SKKU-STEM <span class="font-normal">Laboratory</span>
  </span>
</span>
