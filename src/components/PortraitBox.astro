---
// 멤버 카드용 portrait — public/members/<INIT>.jpg 경로(srcPath)가 있으면 표시, 없으면 점선 placeholder
interface Props {
  srcPath?: string;        // public/ 직접 경로 (예: /members/YMK.jpg)
  alt: string;
  class?: string;
}

const { srcPath, alt, class: className } = Astro.props;
---

{
  srcPath ? (
    <img
      src={srcPath}
      alt={alt}
      loading="lazy"
      class:list={['aspect-[3/4] object-contain bg-cream-200/60 mix-blend-darken', className]}
    />
  ) : (
    <div
      class:list={[
        'aspect-[3/4] bg-cream-200/60 border border-dashed border-ink/15 flex items-center justify-center',
        className,
      ]}
      role="img"
      aria-label={`${alt} placeholder`}
    >
      <span class="font-mono text-[9px] uppercase tracking-[0.18em] text-ink/40 select-none">
        Photo
      </span>
    </div>
  )
}
