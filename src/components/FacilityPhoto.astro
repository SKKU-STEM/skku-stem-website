---
// Facility 장비 사진 슬롯 — slug + index로 src/assets/facilities/<slug>-<index>.{jpg,jpeg,png,webp} 자동 매칭
// 파일이 없으면 점선 placeholder
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  slug: string;
  index: number;
  alt: string;
  class?: string;
  priority?: boolean;
}

const { slug, index, alt, class: className, priority = false } = Astro.props;

const facilityImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/facilities/*.{jpg,jpeg,png,webp}',
  { eager: true }
);

const findImage = (): ImageMetadata | null => {
  for (const ext of ['jpg', 'jpeg', 'png', 'webp']) {
    const mod = facilityImages[`/src/assets/facilities/${slug}-${index}.${ext}`];
    if (mod) return mod.default;
  }
  return null;
};

const image = findImage();
---

{
  image ? (
    <Image
      src={image}
      alt={alt}
      loading={priority ? 'eager' : 'lazy'}
      fetchpriority={priority ? 'high' : 'auto'}
      class:list={['aspect-[4/3] object-contain w-full mix-blend-darken', className]}
    />
  ) : (
    <div
      class:list={[
        'aspect-[4/3] bg-cream-200/60 border border-dashed border-ink/15 flex items-center justify-center',
        className,
      ]}
      role="img"
      aria-label={`${alt} placeholder`}
    >
      <span class="font-mono text-[9px] uppercase tracking-[0.18em] text-ink/65 select-none">
        {slug}-{index}
      </span>
    </div>
  )
}
