---
// 사이트 전체 푸터 — 진한 ink 배경 + cream 텍스트, 우측 외부 링크는 coral hover 확대 애니메이션
const externalLinks: Array<{ href: string; label: string }> = [
  { href: 'https://does.skku.edu/', label: 'Department of Energy Science' },
  {
    href: 'https://www.skku.edu/skku/index.do',
    label: 'Sungkyunkwan University',
  },
  { href: 'https://github.com/SKKU-STEM', label: 'GitHub' },
];
---

<footer class="bg-ink text-cream">
  <div class="container-page py-14 text-sm text-cream/75">
    <div class="grid gap-10 md:grid-cols-2">
      {/* Left — address */}
      <address class="not-italic">
        <p class="font-medium text-cream">SKKU-STEM Laboratory</p>
        <p class="mt-3 leading-relaxed">
          Department of Energy Science<br />
          Sungkyunkwan University<br />
          2066 Seobu-ro, Jangan-gu<br />
          Suwon 16419, Republic of Korea
        </p>
      </address>

      {/* Right — external links (coral, hover scale) */}
      <nav aria-label="External links" class="md:text-right">
        <ul class="flex flex-col md:items-end gap-3">
          {
            externalLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block origin-left md:origin-right text-coral hover:text-coral-400 hover:scale-105 transition-all duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <p
      class="mt-12 pt-6 border-t border-cream/15 text-xs text-cream/50"
    >
      &copy; 2026 SKKU-STEM Lab
    </p>
  </div>
</footer>
