---
// 모든 페이지의 공통 HTML 셸 — Header / Footer / 메타 태그 / skip-link
import '@styles/global.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'SKKU-STEM Lab — 성균관대학교 에너지과학과 김영민 교수 연구실',
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

// OG 이미지: 명시 안 하면 URL slug → /og/<slug>.png 자동 매핑
// (scripts/generate-og.mjs 가 빌드 종료 후 dist/og/ 에 생성)
const pathToSlug = (p: string): string => {
  const trimmed = p.replace(/^\/|\/$/g, '');
  if (!trimmed) return 'home';
  return trimmed.replace(/\//g, '-');
};
const resolvedOgImage =
  ogImage ?? new URL(`/og/${pathToSlug(Astro.url.pathname)}.png`, Astro.site).toString();

// Cloudflare Web Analytics — token이 환경변수로 주입되면 prod에서 beacon 자동 로드
const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="256x256" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="SKKU-STEM Lab — News"
      href="/rss.xml"
    />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={resolvedOgImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
  </head>

  <body class="bg-cream text-ink font-sans antialiased min-h-dvh flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:bg-cream focus:text-ink focus:px-3 focus:py-2 focus:rounded-md focus:shadow-soft"
    >
      Skip to content
    </a>

    <Header />

    <main id="main" class="flex-1">
      <slot />
    </main>

    <Footer />

    {
      cfAnalyticsToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${cfAnalyticsToken}"}`}
        />
      )
    }
  </body>
</html>
